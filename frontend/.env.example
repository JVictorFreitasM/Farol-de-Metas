# Opcional para desenvolvimento local direto (sem Docker) — não é necessário
# copiar este arquivo para rodar via `docker compose up`, o docker-compose.yml
# já define estes valores para o container do frontend.

# Para onde o proxy /api do Vite deve apontar. Dentro do Docker Compose, o
# docker-compose.yml sobrescreve isso para http://backend:3000.
VITE_API_PROXY_TARGET="http://localhost:3000"

# Porta que o cliente de HMR deve usar para reconectar. Só é necessário quando
# a porta publicada no host difere da porta interna do Vite (caso do Docker,
# onde o host usa 5174 mas o Vite roda em 5173 dentro do container).
VITE_HMR_CLIENT_PORT=""

# Necessário em Docker (bind mounts do Docker Desktop não propagam eventos
# nativos de filesystem de forma confiável) para que o watcher do Vite detecte
# alterações de arquivo. O docker-compose.yml já define isso como "true".
VITE_WATCH_USE_POLLING="false"
