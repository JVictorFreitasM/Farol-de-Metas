generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  responsavel
  gerente
  admin

  @@map("user_role")
}

enum IcIv {
  IC
  IV

  @@map("ic_iv_type")
}

enum TipoMeta {
  maior_melhor
  menor_melhor

  @@map("tipo_meta_type")
}

enum StatusMeta {
  ok
  nok

  @@map("status_meta_type")
}

enum AcaoAuditoria {
  CREATE
  READ
  UPDATE
  DELETE

  @@map("acao_auditoria_type")
}

enum StatusProduto {
  ativo
  inativo

  @@map("status_produto_type")
}

// OS-009: regras de agregação de um IC (agrega_filhos=true) a partir dos IVs filhos.
// Meta e Real têm enums separados porque cada lado só aceita um subconjunto de regras:
// meta_manual só faz sentido para a Meta (valor fixo digitado), proporcao_agregada só para o Real
// (razão soma dos reais / soma das metas dos filhos).
enum TipoAgregacaoMeta {
  soma
  media
  meta_manual

  @@map("tipo_agregacao_meta_type")
}

enum TipoAgregacaoReal {
  soma
  media
  proporcao_agregada
  real_manual // OS-014: Real do IC não deriva dos filhos, é digitado direto (mesmo padrão do meta_manual)

  @@map("tipo_agregacao_real_type")
}

model Setor {
  id           String   @id @default(uuid()) @db.Uuid
  nome         String   @unique @db.VarChar(255)
  email        String?  @unique @db.VarChar(255)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @default(now()) @map("atualizado_em")

  usuarios    Usuario[]
  metas       Meta[]
  produtos    Produto[]
  indicadores Indicador[]
  auditorias  Auditoria[]

  @@index([nome])
  @@index([email])
  @@map("setores")
}

model Produto {
  id                   String        @id @default(uuid()) @db.Uuid
  nome                 String        @db.VarChar(255)
  descricao            String?
  setorId              String        @map("setor_id") @db.Uuid
  setor                Setor         @relation(fields: [setorId], references: [id])
  status               StatusProduto @default(ativo)
  criadoPor            String        @map("criado_por") @db.Uuid
  criadoPorUsuario     Usuario       @relation("ProdutoCriadoPor", fields: [criadoPor], references: [id])
  criadoEm             DateTime      @default(now()) @map("criado_em")
  atualizadoEm         DateTime      @default(now()) @map("atualizado_em")
  atualizadoPor        String?       @map("atualizado_por") @db.Uuid
  atualizadoPorUsuario Usuario?      @relation("ProdutoAtualizadoPor", fields: [atualizadoPor], references: [id])

  indicadores Indicador[]

  @@unique([nome, setorId])
  @@index([setorId, status])
  @@index([nome])
  @@index([criadoEm])
  @@map("produtos")
}

// OS-013: dados fixos do indicador (nome, unidade, hierarquia, regras de agregação) —
// não variam por ano. Cada ano é uma linha em Meta apontando para o mesmo Indicador.
model Indicador {
  id      String @id @default(uuid()) @db.Uuid
  setorId String @map("setor_id") @db.Uuid
  setor   Setor  @relation(fields: [setorId], references: [id])

  nome    String @db.VarChar(500)
  icIv    IcIv   @map("ic_iv")
  unidade String @db.VarChar(50)

  paiId  String?     @map("pai_id") @db.Uuid
  pai    Indicador?  @relation("IndicadorHierarquia", fields: [paiId], references: [id])
  filhos Indicador[] @relation("IndicadorHierarquia")

  produtoId String?  @map("produto_id") @db.Uuid
  produto   Produto? @relation(fields: [produtoId], references: [id])

  agregaFilhos      Boolean           @default(false) @map("agrega_filhos")
  // OS-015: "soma" | "media" | "manual", em separado pro lado Meta e pro lado Real — nem
  // sempre os dois lados de um indicador seguem a mesma regra de acumulação. "manual" significa
  // que os 12 meses continuam preenchidos normalmente (histórico/rastreio), mas o acumulado
  // final vem de meta.acumMetaManual/meta.acumRealManual em vez de ser calculado a partir deles
  // (ver metasCalc.calcularAcumuladoLinha).
  tipoAcumuladoMeta String            @default("soma") @map("tipo_acumulado_meta") @db.VarChar(10)
  tipoAcumuladoReal String            @default("soma") @map("tipo_acumulado_real") @db.VarChar(10)
  tipoAgregacaoMeta TipoAgregacaoMeta @default(soma) @map("tipo_agregacao_meta")
  tipoAgregacaoReal TipoAgregacaoReal @default(soma) @map("tipo_agregacao_real")
  // OS-015: valor fixo de real acumulado do IC, usado quando tipo_agregacao_real = real_manual
  // (mesmo padrão do metaManualAcum, mas para o lado do Real de um IC agregador).
  realManualAcum    Decimal?          @map("real_manual_acum") @db.Decimal(15, 4)

  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @default(now()) @map("atualizado_em")

  metas Meta[]

  @@unique([nome, setorId])
  @@index([setorId])
  @@index([paiId])
  @@index([produtoId])
  @@map("indicadores")
}

model Usuario {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  senhaHash    String    @map("senha_hash") @db.VarChar(255)
  setorId      String?   @map("setor_id") @db.Uuid
  setor        Setor?    @relation(fields: [setorId], references: [id])
  nome         String    @db.VarChar(255)
  role         UserRole
  ativo        Boolean   @default(true)
  ultimoAcesso DateTime? @map("ultimo_acesso")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @default(now()) @map("atualizado_em")

  metasAtualizadas    Meta[]          @relation("MetaAtualizadoPor")
  metasInativadas     Meta[]          @relation("MetaInativadoPor")
  historicos          MetaHistorico[]
  auditorias          Auditoria[]
  produtosCriados     Produto[]       @relation("ProdutoCriadoPor")
  produtosAtualizados Produto[]       @relation("ProdutoAtualizadoPor")

  @@index([email])
  @@index([setorId])
  @@index([role])
  @@map("usuarios")
}

model Meta {
  id      String @id @default(uuid()) @db.Uuid
  // Denormalizado a partir de indicador.setorId — mantido direto na linha para queries de
  // dashboard (filtro por setor+ano) sem precisar de join em indicadores.
  setorId String @map("setor_id") @db.Uuid
  setor   Setor  @relation(fields: [setorId], references: [id])
  ano     Int

  // OS-013: nome, unidade, hierarquia e regras de agregação vivem em Indicador (fixos,
  // não variam por ano). Meta guarda só o que muda ano a ano.
  indicadorId String    @map("indicador_id") @db.Uuid
  indicador   Indicador @relation(fields: [indicadorId], references: [id])

  // Ordem de exibição (preserva sequência do Excel)
  ordem Int @default(0)

  responsavel String   @db.VarChar(255)
  tipoMeta    TipoMeta @map("tipo_meta")

  // Valor fixo de meta acumulada, usado quando indicador.tipo_agregacao_meta = meta_manual
  // (IC agregador — Meta não deriva dos filhos). Hoje vestigial: a Meta desses ICs é digitada
  // mês a mês (ver PUT /:id/meta), e o acumulado vem de acumMetaManual/tipo_acumulado_meta.
  metaManualAcum Decimal? @map("meta_manual_acum") @db.Decimal(15, 4)

  // OS-015: valor fixo de acumulado, usado quando indicador.tipo_acumulado_meta/tipo_acumulado_real
  // = "manual". Os 12 meses continuam preenchidos normalmente (histórico/rastreio); este campo
  // apenas sobrescreve o que seria soma/média deles no acumulado final.
  acumMetaManual Decimal? @map("acum_meta_manual") @db.Decimal(15, 4)
  acumRealManual Decimal? @map("acum_real_manual") @db.Decimal(15, 4)

  // Meta anual (definida pelo gerente)
  metaAno Decimal? @map("meta_ano") @db.Decimal(15, 4)

  // Meta por mês — definida pelo GERENTE (uma vez por ano)
  metaJan Decimal? @map("meta_jan") @db.Decimal(15, 4)
  metaFev Decimal? @map("meta_fev") @db.Decimal(15, 4)
  metaMar Decimal? @map("meta_mar") @db.Decimal(15, 4)
  metaAbr Decimal? @map("meta_abr") @db.Decimal(15, 4)
  metaMai Decimal? @map("meta_mai") @db.Decimal(15, 4)
  metaJun Decimal? @map("meta_jun") @db.Decimal(15, 4)
  metaJul Decimal? @map("meta_jul") @db.Decimal(15, 4)
  metaAgo Decimal? @map("meta_ago") @db.Decimal(15, 4)
  metaSet Decimal? @map("meta_set") @db.Decimal(15, 4)
  metaOut Decimal? @map("meta_out") @db.Decimal(15, 4)
  metaNov Decimal? @map("meta_nov") @db.Decimal(15, 4)
  metaDez Decimal? @map("meta_dez") @db.Decimal(15, 4)

  // Real por mês — definido pelo RESPONSÁVEL mensalmente
  realJan Decimal? @map("real_jan") @db.Decimal(15, 4)
  realFev Decimal? @map("real_fev") @db.Decimal(15, 4)
  realMar Decimal? @map("real_mar") @db.Decimal(15, 4)
  realAbr Decimal? @map("real_abr") @db.Decimal(15, 4)
  realMai Decimal? @map("real_mai") @db.Decimal(15, 4)
  realJun Decimal? @map("real_jun") @db.Decimal(15, 4)
  realJul Decimal? @map("real_jul") @db.Decimal(15, 4)
  realAgo Decimal? @map("real_ago") @db.Decimal(15, 4)
  realSet Decimal? @map("real_set") @db.Decimal(15, 4)
  realOut Decimal? @map("real_out") @db.Decimal(15, 4)
  realNov Decimal? @map("real_nov") @db.Decimal(15, 4)
  realDez Decimal? @map("real_dez") @db.Decimal(15, 4)

  // Status por mês — GENERATED ALWAYS AS no banco (calculado automaticamente)
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusJan StatusMeta? @map("status_jan")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusFev StatusMeta? @map("status_fev")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusMar StatusMeta? @map("status_mar")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusAbr StatusMeta? @map("status_abr")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusMai StatusMeta? @map("status_mai")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusJun StatusMeta? @map("status_jun")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusJul StatusMeta? @map("status_jul")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusAgo StatusMeta? @map("status_ago")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusSet StatusMeta? @map("status_set")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusOut StatusMeta? @map("status_out")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusNov StatusMeta? @map("status_nov")
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusDez StatusMeta? @map("status_dez")

  // Acumulados — calculados pelo backend e armazenados
  // (não podem ser GENERATED pois dependem de tipo_acumulado e de filhos)
  acumMeta   Decimal?    @map("acum_meta") @db.Decimal(15, 4)
  acumReal   Decimal?    @map("acum_real") @db.Decimal(15, 4)
  /// Coluna gerada pelo banco. Não gravar via Prisma Client.
  statusAcum StatusMeta? @map("status_acum")

  // Controle
  criadoEm             DateTime @default(now()) @map("criado_em")
  atualizadoEm         DateTime @default(now()) @map("atualizado_em")
  atualizadoPor        String?  @map("atualizado_por") @db.Uuid
  atualizadoPorUsuario Usuario? @relation("MetaAtualizadoPor", fields: [atualizadoPor], references: [id])

  // Inativação (soft delete) — ver OS-008
  ativo               Boolean   @default(true)
  inativadoEm         DateTime? @map("inativado_em")
  inativadoPor        String?   @map("inativado_por") @db.Uuid
  inativadoPorUsuario Usuario?  @relation("MetaInativadoPor", fields: [inativadoPor], references: [id])

  historicos MetaHistorico[]

  @@index([setorId])
  @@index([ano])
  @@index([indicadorId])
  @@index([indicadorId, ano])
  @@index([setorId, ano])
  @@index([setorId, ano, ordem])
  @@index([ativo])
  @@index([setorId, ativo])
  @@map("metas")
}

model MetaHistorico {
  id                 String   @id @default(uuid()) @db.Uuid
  metasId            String   @map("metas_id") @db.Uuid
  meta               Meta     @relation(fields: [metasId], references: [id])
  versao             Int
  valoresAntes       Json?    @map("valores_antes")
  valoresDepois      Json     @map("valores_depois")
  alteradoPor        String?  @map("alterado_por") @db.Uuid
  alteradoPorUsuario Usuario? @relation(fields: [alteradoPor], references: [id])
  alteradoEm         DateTime @default(now()) @map("alterado_em")
  motivo             String?

  @@index([metasId])
  @@index([alteradoEm])
  @@map("metas_historico")
}

model Auditoria {
  id         String        @id @default(uuid()) @db.Uuid
  setorId    String?       @map("setor_id") @db.Uuid
  setor      Setor?        @relation(fields: [setorId], references: [id])
  usuarioId  String?       @map("usuario_id") @db.Uuid
  usuario    Usuario?      @relation(fields: [usuarioId], references: [id])
  acao       AcaoAuditoria
  tabela     String        @db.VarChar(50)
  registroId String?       @map("registro_id") @db.Uuid
  ipAddress  String?       @map("ip_address") @db.VarChar(45)
  timestamp  DateTime      @default(now())
  detalhes   Json?

  @@index([setorId])
  @@index([usuarioId])
  @@index([timestamp])
  @@index([acao])
  @@map("auditoria")
}
